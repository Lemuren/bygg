#!/bin/sh

VERBOSE=0

# Print a failure message and exit.
fail() { echo "error: $1" >&2; exit 1; }

# Print a debug message, i.e. if VERBOSE is set to true.
# shellcheck disable=SC2244,SC2059
debug() { [ "${VERBOSE}" -eq 1 ] && printf "$*\n"; }

# Initialize a new, empty queue.
queue_init() { QUEUE="main"; QHEAD=1; }

# Push an element onto the end of the queue.
queue_push() { QUEUE="${QUEUE} $1" ; }

# Retrieve the next element of the queue without popping it.
# shellcheck disable=SC2086
queue_get() { printf '%s\n' ${QUEUE} | sed -n "${QHEAD}p"; }

# Check if an element is contained in a queue.
queue_contains() {
    for q in ${QUEUE}; do
        [ "$1" = "${q}" ] && return 0
    done
    return 1
}

# Return the length of a queue.
queue_len() { echo "${QUEUE}" | wc -w; }

# Parse the module name from a .bygg file.
get_module_name() { head -n 1 "$1"; }

# Parse the imports from a .bygg file.
get_imports() { tail -n +2 "$1"; }

find_module_dir() {
    dir=$(find "${SRC_DIR}" -type f -name "$1.bygg" -printf '%h' -quit)
    [ -n "${dir}" ] || return 1
    printf '%s\n' "${dir}"
}

build_module() {
    mod="$1"
    moddir=$(find_module_dir "${mod}") || fail "could not locate module ${mod}"
    byggfile="${moddir}/${mod}.bygg"

    # Print feedback on number of modules compiled and how many remain.
    # shellcheck disable=SC2312
    printf "[%d/%d] %s\n" "${QHEAD}" "$(queue_len)" "${mod}"
    debug "module dir: ${moddir}"
    debug "bygg file: ${byggfile}"

    # 1. Generate amalgamation file
    amalg="${BUILD_DIR}/${mod}_all.c"
    echo "// amalgamation for ${mod}" > "${amalg}"
    debug "generating amalgamation ${amalg}"

    # Include all .c files in the module directory.
    for c in "${moddir}"/*.c; do
        [ -e "${c}" ] || continue
        echo "#include \"$(basename "${c}")\"" >> "${amalg}"
        debug "\t+ ${c}"
    done

    # 2. Compute include paths from direct imports.
    includes="${moddir}"
    for dep in $(get_imports "${byggfile}"); do
        depdir=$(find_module_dir "${dep}")
        includes="${includes} ${depdir}"
    done

    # 3. Compile module into .o
    obj="${BUILD_DIR}/${mod}.o"
    set -- gcc -Wno-error=implicit-function-declaration -Wno-implicit-function-declaration
    for inc in ${includes}; do
        set -- "$@" -I "${inc}"
    done
    set -- "$@" -c "${amalg}" -o "${obj}"
    "$@" || fail "compiling ${mod} failed"

    # 4. Archive into static library
    lib="${BUILD_DIR}/${mod}.a"
    ar rcs "${lib}" "${obj}" || fail "archiving ${mod} failed"
}



SRC_DIR="$(cd -- "$(dirname -- "$1")" && pwd)"
BUILD_DIR="$(cd -- "$(dirname -- "$2")" && pwd)"
SRC_DIR="${SRC_DIR}"/$(basename "$1")
BUILD_DIR="${BUILD_DIR}"/$(basename "$2")
debug "source dir: ${SRC_DIR}"
debug "build dir: ${BUILD_DIR}"


# Create the build directory.
mkdir -p "${BUILD_DIR}"


# Initialize queue with the main module.
stat "${SRC_DIR}/main.bygg" >/dev/null 2>&1 || fail "no main.bygg"
queue_init

# Process queue
while :; do
    # Fetch next module from the queue.
    mod=$(queue_get)
    [ -z "${mod}" ] && break

    # Build the module.
    build_module "${mod}"

    # Enqueue its imports if not already present
    moddir=$(find_module_dir "${mod}")
    for dep in $(get_imports "${moddir}/${mod}.bygg"); do
        queue_contains "${dep}" && continue
        queue_push "${dep}"
    done

    QHEAD=$((QHEAD + 1))
done

# Link.
set -- gcc
for mod in ${QUEUE}; do
    set -- "$@" "${BUILD_DIR}/${mod}.a"
done
set -- "$@" -o "${BUILD_DIR}/a.out"
"$@" || exit 1
