#!/bin/sh

fail() {
    msg="$1"
    echo "error: ${msg}"
    exit 1
}

get_module_name() {
    head -n 1 "$1"
}

get_imports() {
    tail -n +2 "$1"
}

find_module_dir() {
    find "${SRC_DIR}" -type f -name "$1.bygg" -printf '%h' -quit
}

build_module() {
    mod="$1"
    moddir=$(find_module_dir "${mod}")
    bygg="${moddir}/${mod}.bygg"

    echo "=== Building module ${mod} ==="

    # 1. Generate amalgamation file
    amalg="${BUILD_DIR}/${mod}_all.c"
    echo "// amalgamation for ${mod}" > "${amalg}"

    # Include all .c files in the module directory
    for c in "${moddir}"/*.c; do
        echo "#include \"$(basename "${c}")\"" >> "${amalg}"
    done

    # 2. Compute include paths from direct imports.
    includes="${SRC_DIR}/${mod}"
    for dep in $(get_imports "${bygg}"); do
        includes="${includes} ${SRC_DIR}/${dep}"
    done

    # 3. Compile module into .o
    obj="${BUILD_DIR}/${mod}.o"
    set -- gcc -Wno-error=implicit-function-declaration
    for inc in ${includes}; do
        set -- "$@" -I "${inc}"
    done
    set -- "$@" -c "${amalg}" -o "${obj}"
    "$@" || exit 1

    # 4. Archive into static library
    lib="${BUILD_DIR}/${mod}.a"
    ar rcs "${lib}" "${obj}" || exit 1
}



QUEUE=""
QHEAD=1

SRC_DIR="$(cd -- "$(dirname -- "$1")" && pwd)"
BUILD_DIR="$(cd -- "$(dirname -- "$2")" && pwd)"
SRC_DIR="${SRC_DIR}"/$(basename "$1")
BUILD_DIR="${BUILD_DIR}"/$(basename "$2")


stat "${SRC_DIR}/main.bygg" >/dev/null 2>&1 || fail "no main.bygg"
mkdir -p "${BUILD_DIR}"

# Seed queue with main imports
for dep in $(get_imports "${SRC_DIR}/main.bygg"); do
    if [ -n "${QUEUE}" ]; then
        QUEUE="${QUEUE} ${dep}"
    else
        QUEUE="${dep}"
    fi
done

# Process queue
while :; do
    # shellcheck disable=SC2086
    mod=$(printf "%s\n" ${QUEUE} | sed -n "${QHEAD}p")
    [ -z "${mod}" ] && break

    # Build module
    echo "Building ${mod}"
    build_module "${mod}"

    # Enqueue its imports if not already present
    for dep in $(get_imports "${SRC_DIR}/${mod}/${mod}.bygg"); do
        found=false
        for q in ${QUEUE}; do
            [ "${q}" = "${dep}" ] && found=true && break
        done
        if [ -n "${QUEUE}" ]; then
            ${found} || QUEUE="${QUEUE} ${dep}"
        else
            ${found} || QUEUE="${dep}"
        fi
        echo "QUEUE: ${QUEUE}"
    done

    QHEAD=$((QHEAD + 1))
done

# Resolve main include directives.
includes=""
for dep in $(get_imports "${SRC_DIR}/main.bygg"); do
    if [ -n "${includes}" ]; then
        includes="${includes} ${SRC_DIR}/${dep}"
    else
        includes="${SRC_DIR}/${dep}"
    fi
done

# Compile.
set -- gcc
for inc in ${includes}; do
    set -- "$@" -I "${inc}"
done
set -- "$@" -c "${SRC_DIR}/main.c" -o "${BUILD_DIR}/main.o"
"$@" || exit 1


# Construct archive string.
archives=""
for mod in ${QUEUE}; do
    if [ -n "${archives}" ]; then
        archives="${archives} ${BUILD_DIR}/${mod}.a"
    else
        archives="${BUILD_DIR}/${mod}.a"
    fi
done

# Link.
set -- gcc "${BUILD_DIR}/main.o"
for arc in ${archives}; do
    set -- "$@" "${arc}"
done
set -- "$@" -o "${BUILD_DIR}/a.out"
"$@" || exit 1
